{
  "include": ["core", "github_activity_tracker", "discord_activity_tracker"],
  "exclude": [
    "**/.venv/**",
    "**/migrations/**",
    "**/__pycache__/**",
    "**/tests/**",
    "core/pyright_samples/**",
    "**/._*",
    "**/.___*"
  ],
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "reportMissingImports": true,
  "executionEnvironments": [
    {
      "root": "github_activity_tracker",
      "extraPaths": ["."],
      "reportAttributeAccessIssue": "none",
      "reportArgumentType": "none",
      "reportAssignmentType": "none",
      "reportCallIssue": "none",
      "reportIndexIssue": "none",
      "reportGeneralTypeIssues": "none"
    },
    {
      "root": "discord_activity_tracker",
      "extraPaths": ["."],
      "reportAttributeAccessIssue": "none",
      "reportArgumentType": "none",
      "reportAssignmentType": "none",
      "reportCallIssue": "none",
      "reportIndexIssue": "none",
      "reportGeneralTypeIssues": "none"
    }
  ]
}
